From a6136fc92961173fb972e0d8db0bad528f966d31 Mon Sep 17 00:00:00 2001
From: Shizhao Liu <lshizhao@amazon.com>
Date: Fri, 26 Sep 2025 21:34:30 -0700
Subject: [PATCH 16/16] Resilliency improvements for image-builder workflows

1. Make ansible_firstboot_timeout and ansible_node_timeout configurable
2. Make ansible_common_ssh_args configurable
3. Add new flag to skip rhel subscription

Signed-off-by: Shizhao Liu <lshizhao@amazon.com>
---
 images/capi/ansible/roles/setup/tasks/redhat.yml | 6 ++++++
 images/capi/packer/config/ansible-args.json      | 1 -
 images/capi/packer/ova/packer-node.json          | 8 ++++++--
 3 files changed, 12 insertions(+), 3 deletions(-)

diff --git a/images/capi/ansible/roles/setup/tasks/redhat.yml b/images/capi/ansible/roles/setup/tasks/redhat.yml
index 2a98dae54..8e2374cb0 100644
--- a/images/capi/ansible/roles/setup/tasks/redhat.yml
+++ b/images/capi/ansible/roles/setup/tasks/redhat.yml
@@ -24,6 +24,7 @@
     - lookup('env', 'RHSM_PASS') | length > 0
     - rhsm_server_hostname == ""
     - rhsm_server_proxy_hostname == ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: RHEL subscription with proxy
   redhat_subscription:
@@ -39,6 +40,7 @@
     - lookup('env', 'RHSM_PASS') | length > 0
     - rhsm_server_hostname == ""
     - rhsm_server_proxy_hostname != ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: Download Katello CA Consumer RPM from Satellite Server
   get_url:
@@ -50,6 +52,7 @@
   when:
     - ansible_distribution == "RedHat"
     - rhsm_server_hostname != ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: Install Katello CA Consumer RPM from Satellite Server
   yum:
@@ -60,6 +63,7 @@
   when:
     - ansible_distribution == "RedHat"
     - rhsm_server_hostname != ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: RHEL subscription with satellite using activation key
   redhat_subscription:
@@ -74,6 +78,7 @@
     - lookup('env', 'RHSM_ORG_ID') | length > 0
     - rhsm_server_hostname != ""
     - rhsm_server_proxy_hostname == ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: RHEL subscription with satellite and proxy
   redhat_subscription:
@@ -90,6 +95,7 @@
     - lookup('env', 'RHSM_ORG_ID') | length > 0
     - rhsm_server_hostname != ""
     - rhsm_server_proxy_hostname != ""
+    - skip_rhel_subscription | default(false) != true
 
 - name: Perform dnf clean
   ansible.builtin.command: /usr/bin/yum -y clean all
